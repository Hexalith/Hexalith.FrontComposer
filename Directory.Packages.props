<Project>
  <PropertyGroup>
    <ManagePackageVersionsCentrally>true</ManagePackageVersionsCentrally>
  </PropertyGroup>

  <ItemGroup Label="Roslyn">
    <!-- MUST be exactly 4.12.0 — higher versions (5.x) break IDE analyzer load context.
         PrivateAssets="all" is set in the project file, not here. -->
    <PackageVersion Include="Microsoft.CodeAnalysis.CSharp" Version="4.12.0" />
  </ItemGroup>

  <ItemGroup Label="Runtime">
    <!-- System.Collections.Immutable is ONLY needed on netstandard2.0 — net10.0 carries it in-box. -->
    <PackageVersion Include="System.Collections.Immutable" Version="9.0.0" />
    <!-- System.ComponentModel.Annotations is ONLY needed on netstandard2.0 — net10.0 carries it in-box.
         Used by FcShellOptions for [Range] / [RegularExpression] validation. -->
    <PackageVersion Include="System.ComponentModel.Annotations" Version="5.0.0" />
    <!-- Story 3-5 D3 — ValueTask<T> is ONLY needed on netstandard2.0 for the IActionQueueCountReader
         contract; net10.0 carries it in-box. -->
    <PackageVersion Include="System.Threading.Tasks.Extensions" Version="4.6.3" />
    <!-- Story 2-4 Task 3.4 — OptionsBuilder<T>.ValidateDataAnnotations() extension for FcShellOptions. -->
    <PackageVersion Include="Microsoft.Extensions.Options.DataAnnotations" Version="9.0.0" />
    <!-- Story 3-1 Task 8.2 — IStringLocalizer<FcShellResources> + AddLocalization() for the
         Quickstart chain. Adopters who don't use the shell localization still get AddLocalization
         transitively via the web SDK; Shell owning the package keeps the granular API surface honest. -->
    <PackageVersion Include="Microsoft.Extensions.Localization" Version="9.0.0" />
    <!-- Story 2-3 Decision D3: ULID generation for MessageId idempotency (FR36/NFR45).
         Story spec pinned 1.7.4; nuget.org published 1.7.3 — latest stable at implementation time. -->
    <PackageVersion Include="NUlid" Version="1.7.3" />
    <!-- Story 3-5 D5 — explicit dependency on System.Reactive for the BadgeCountService
         `Subject<T>` + `.AsObservable()` producer/consumer isolation pattern. Declared
         explicitly (rather than relying on a transitive pull from Fluent UI v5) so a future
         minor bump cannot silently drop the dependency. -->
    <PackageVersion Include="System.Reactive" Version="6.0.1" />
  </ItemGroup>

  <ItemGroup Label="Blazor">
    <!-- Fluent UI v5 RC2 available on public NuGet (Path 1 from story spec).
         ADR-003: build on v5 RC, pin exact version. -->
    <PackageVersion Include="Microsoft.FluentUI.AspNetCore.Components" Version="5.0.0-rc.2-26098.1" />
    <PackageVersion Include="Fluxor.Blazor.Web" Version="6.9.0" />
  </ItemGroup>

  <ItemGroup Label="Aspire">
    <PackageVersion Include="Aspire.Hosting.AppHost" Version="13.2.1" />
  </ItemGroup>

  <ItemGroup Label="Testing">
    <!-- xUnit v3 to match EventStore submodule — bUnit 2.7.2 is compatible -->
    <PackageVersion Include="xunit.v3" Version="3.2.2" />
    <PackageVersion Include="xunit.v3.assert" Version="3.2.2" />
    <PackageVersion Include="xunit.runner.visualstudio" Version="3.1.5" />
    <PackageVersion Include="bunit" Version="2.7.2" />
    <PackageVersion Include="Shouldly" Version="4.3.0" />
    <PackageVersion Include="NSubstitute" Version="5.3.0" />
    <PackageVersion Include="coverlet.collector" Version="8.0.1" />
    <PackageVersion Include="Microsoft.NET.Test.Sdk" Version="18.3.0" />
    <!-- Verify snapshot testing — XunitV3 for xUnit v3 (NOT Verify.Xunit which is v2) -->
    <PackageVersion Include="Verify" Version="31.15.0" />
    <PackageVersion Include="Verify.XunitV3" Version="31.15.0" />
    <!-- FsCheck property-based testing (Story 2.1 adds FsCheck.Xunit.v3 for xUnit v3 integration) -->
    <PackageVersion Include="FsCheck.Xunit.v3" Version="3.3.1" />
    <!-- Story 2-4 Task 0.3 — FakeTimeProvider for deterministic ITimer-callback-driven threshold tests. -->
    <PackageVersion Include="Microsoft.Extensions.TimeProvider.Testing" Version="9.0.0" />
    <!-- Story 3-7 T2 — BenchmarkDotNet for PaletteScorerBench (AC5). Runs in the
         tests/Hexalith.FrontComposer.Shell.Tests.Bench project under [Trait("Category", "Performance")]. -->
    <PackageVersion Include="BenchmarkDotNet" Version="0.15.4" />
  </ItemGroup>
</Project>
