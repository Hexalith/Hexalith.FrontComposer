<Project>
  <!-- Local root-declared submodule ProjectReference paths (default for dev + CI) -->
  <!-- EventStore is ALWAYS from references/Hexalith.EventStore, never Tenants' nested copy -->
  <PropertyGroup>
    <EventStorePath>$(MSBuildThisFileDirectory)references/Hexalith.EventStore</EventStorePath>
    <TenantsPath>$(MSBuildThisFileDirectory)references/Hexalith.Tenants</TenantsPath>
  </PropertyGroup>
</Project>
