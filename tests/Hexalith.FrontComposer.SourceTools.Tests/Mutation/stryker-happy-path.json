{
  "$schema": "https://raw.githubusercontent.com/stryker-mutator/stryker-net/master/src/Stryker.CLI/Stryker.CLI/stryker-schema.json",
  "stryker-config": {
    "solution": "Hexalith.FrontComposer.slnx",
    "project": "src/Hexalith.FrontComposer.SourceTools/Hexalith.FrontComposer.SourceTools.csproj",
    "test-projects": [
      "tests/Hexalith.FrontComposer.SourceTools.Tests/Hexalith.FrontComposer.SourceTools.Tests.csproj"
    ],
    "reporters": [
      "progress",
      "html",
      "json"
    ],
    "report-file-name": "source-tools-happy-path",
    "mutation-level": "Standard",
    "thresholds": {
      "high": 80,
      "low": 80,
      "break": 80
    },
    "coverage-analysis": "perTest",
    "concurrency": 4,
    "test-case-filter": "Category!=MutationErrorHandling&Category!=Performance",
    "mutate": [
      "Parsing/**/*.cs",
      "Transforms/**/*.cs",
      "!Emitters/**/*.cs",
      "!**/*.g.cs",
      "!**/*.generated.cs",
      "!**/obj/**/*.cs",
      "!**/bin/**/*.cs"
    ],
    "ignore-methods": [
      "*Log",
      "Console.Write*",
      "*Exception.ctor"
    ]
  }
}
