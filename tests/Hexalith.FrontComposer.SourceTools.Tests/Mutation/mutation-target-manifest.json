{
  "schemaVersion": "1.0",
  "ownerStory": "10-4-mutation-testing-and-property-based-testing",
  "approvedTargetRoots": [
    "src/Hexalith.FrontComposer.SourceTools/Parsing",
    "src/Hexalith.FrontComposer.SourceTools/Transforms"
  ],
  "segments": [
    {
      "name": "happy-path",
      "config": "tests/Hexalith.FrontComposer.SourceTools.Tests/Mutation/stryker-happy-path.json",
      "threshold": 80,
      "artifactPrefix": "source-tools-happy-path"
    },
    {
      "name": "error-handling",
      "config": "tests/Hexalith.FrontComposer.SourceTools.Tests/Mutation/stryker-error-handling.json",
      "threshold": 60,
      "artifactPrefix": "source-tools-error-handling"
    }
  ],
  "explicitExclusions": [
    {
      "path": "src/Hexalith.FrontComposer.SourceTools/Emitters/**",
      "reason": "Emitter mutation coverage is out of Story 10-4 scope; snapshots are expensive and reserved for a future SourceTools quality story.",
      "owner": "Future SourceTools quality story"
    },
    {
      "path": "tests/Hexalith.FrontComposer.SourceTools.Tests/**",
      "reason": "Test fixtures and snapshots must not be mutation targets.",
      "owner": "Story 10-4"
    },
    {
      "path": "src/Hexalith.FrontComposer.SourceTools/**/*.g.cs",
      "reason": "Generated source must not be mutated.",
      "owner": "Story 10-4"
    }
  ],
  "triageActions": [
    "kill-test-added",
    "equivalent-accepted",
    "deferred-with-owner",
    "blocking"
  ]
}
