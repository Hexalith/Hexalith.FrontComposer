# Environment configuration for Playwright E2E tests
# Copy to .env.local (gitignored) and override values as needed.

# Test environment label (dev | local | ci | staging)
TEST_ENV=local

# Base URL of the Blazor web app under test.
# For the Counter sample, start the AppHost first (dotnet run --project samples/Counter/Counter.AppHost)
# and use the URL it logs for the Counter.Web service.
BASE_URL=https://localhost:7000

# API base URL (if E2E tests hit REST endpoints directly).
# Point this at whichever service Aspire publishes.
API_URL=https://localhost:7001

# Tenant + user defaults for multi-tenancy architecture row.
# These must match seed data inside Counter.Web / DemoUserContextAccessor.
DEFAULT_TENANT_ID=demo-tenant
DEFAULT_USER_ID=demo-user

# Aspire dashboard (optional, useful when running against AppHost).
ASPIRE_DASHBOARD_URL=https://localhost:17222
