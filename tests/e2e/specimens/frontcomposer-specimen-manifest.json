        "focus-type-command-submit.png",
        "frontcomposer-type-light-compact.png",
        "frontcomposer-type-light-comfortable.png",
        "frontcomposer-type-light-roomy.png",
        "frontcomposer-type-dark-compact.png",
        "frontcomposer-type-dark-comfortable.png",
        "frontcomposer-type-dark-roomy.png"
      ]
    },
    {
      "name": "data-formatting",
