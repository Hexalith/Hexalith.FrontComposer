      "readySelector": "[data-testid='fc-data-formatting-specimen'][data-specimen-ready='true']",
      "landmarkRoot": "[data-testid='fc-data-formatting-specimen']",
      "requiredSections": [
        "[data-testid='fc-data-formatting-grid']",
        "[data-testid='fc-format-row-locale-number']",
        "[data-testid='fc-format-row-absolute-timestamp']",
        "[data-testid='fc-format-row-relative-timestamp']",
        "[data-testid='fc-format-row-truncated-id']",
        "[data-testid='fc-format-row-null-value']",
        "[data-testid='fc-format-row-collection-count']",
        "[data-testid='fc-format-row-currency']",
        "[data-testid='fc-format-row-boolean']",
        "[data-testid='fc-format-row-truncated-enum']",
        "[data-testid='fc-format-row-unsupported']"
      ],
      "expectedArtifacts": [
        "axe-data-formatting.json"
      ]
    }
  ],
  "themeDensityCombinations": [
    { "theme": "light", "density": "compact", "artifact": "frontcomposer-type-light-compact.png" },
    { "theme": "light", "density": "comfortable", "artifact": "frontcomposer-type-light-comfortable.png" },
    { "theme": "light", "density": "roomy", "artifact": "frontcomposer-type-light-roomy.png" },
    { "theme": "dark", "density": "compact", "artifact": "frontcomposer-type-dark-compact.png" },
    { "theme": "dark", "density": "comfortable", "artifact": "frontcomposer-type-dark-comfortable.png" },
    { "theme": "dark", "density": "roomy", "artifact": "frontcomposer-type-dark-roomy.png" }
