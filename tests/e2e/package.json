{
  "name": "hexalith-frontcomposer-e2e",
  "version": "0.0.0",
  "private": true,
  "description": "Playwright E2E test workspace for Hexalith.FrontComposer (Blazor + FluentUI shell + Counter sample)",
  "type": "module",
  "scripts": {
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "test:ui": "playwright test --ui",
    "test:debug": "playwright test --debug",
    "test:chromium": "playwright test --project=chromium",
    "test:firefox": "playwright test --project=firefox",
    "test:webkit": "playwright test --project=webkit",
    "test:smoke": "playwright test specs/smoke.spec.ts",
    "test:lifecycle": "playwright test specs/lifecycle.spec.ts",
    "test:fc-auth": "playwright test specs/policy-gated-command-authorization.spec.ts --project=chromium",
    "test:fc-cnc": "playwright test specs/one-at-a-time-execution-policy.spec.ts --project=chromium",
    "test:fc-retry": "playwright test specs/retry-and-degraded-state-handling.spec.ts --project=chromium",
    "test:fc-tbl": "playwright test specs/fc-tbl-contract.spec.ts --project=chromium",
    "test:abandonment": "playwright test specs/form-abandonment-guard.spec.ts --project=chromium",
    "test:mcp-resources": "playwright test specs/mcp-resources.spec.ts --project=chromium",
    "test:mcp-security": "playwright test specs/mcp-fail-closed-security.spec.ts --project=chromium",
    "test:a11y": "playwright test specs/specimen-accessibility.spec.ts --project=chromium",
    "test:visual": "playwright test specs/specimen-accessibility.spec.ts --project=chromium --grep \"visual baseline\"",
    "test:visual:update": "playwright test specs/specimen-accessibility.spec.ts --project=chromium --grep \"visual baseline\" --update-snapshots",
    "validate:a11y-artifacts": "node scripts/validate-a11y-artifacts.mjs",
    "validate:visual-governance": "node scripts/validate-visual-baseline-governance.mjs",
    "install:browsers": "playwright install --with-deps",
    "report": "playwright show-report",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.0",
    "@faker-js/faker": "^9.0.0",
    "@playwright/test": "^1.49.0",
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
