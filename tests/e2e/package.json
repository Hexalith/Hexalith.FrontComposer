{
  "name": "hexalith-frontcomposer-e2e",
  "version": "0.0.0",
  "private": true,
  "description": "Playwright E2E test workspace for Hexalith.FrontComposer (Blazor + FluentUI shell + Counter sample)",
  "type": "module",
  "scripts": {
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "test:ui": "playwright test --ui",
    "test:debug": "playwright test --debug",
    "test:chromium": "playwright test --project=chromium",
    "test:firefox": "playwright test --project=firefox",
    "test:webkit": "playwright test --project=webkit",
    "test:smoke": "playwright test specs/smoke.spec.ts",
    "test:lifecycle": "playwright test specs/lifecycle.spec.ts",
    "install:browsers": "playwright install --with-deps",
    "report": "playwright show-report",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.0",
    "@faker-js/faker": "^9.0.0",
    "@playwright/test": "^1.49.0",
    "@seontechnologies/playwright-utils": "^1.0.0",
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
