  <Folder Name="/src/">
    <!-- Source-mode Aspire host: built only in Debug, like Hexalith.FrontComposer.UI and every
         references/* source project below (all '<Build Solution="Release|*" Project="false" />').
         The AppHost hard-references source-only dependencies (EventStore.Aspire, FrontComposer.UI,
         Counter.Web), so it cannot participate in the Release package-boundary build, which excludes
         those sources. Building it in Release previously left it with no restored assets and no
         source graph (NETSDK1004 / ASPIRE002 / CS0234). CI builds Release, so the AppHost is
         exercised by Debug/local builds and the Aspire test tier rather than the Release CI build. -->
    <Project Path="src/Hexalith.FrontComposer.AppHost/Hexalith.FrontComposer.AppHost.csproj">
      <Build Solution="Release|*" Project="false" />
    </Project>
    <Project Path="src/Hexalith.FrontComposer.Cli/Hexalith.FrontComposer.Cli.csproj" />
    <Project Path="src/Hexalith.FrontComposer.Contracts/Hexalith.FrontComposer.Contracts.csproj" />
    <Project Path="src/Hexalith.FrontComposer.Contracts.UI/Hexalith.FrontComposer.Contracts.UI.csproj" />
    <Project Path="src/Hexalith.FrontComposer.Mcp/Hexalith.FrontComposer.Mcp.csproj" />
    <Project Path="src/Hexalith.FrontComposer.Schema/Hexalith.FrontComposer.Schema.csproj" />
    <Project Path="src/Hexalith.FrontComposer.Shell/Hexalith.FrontComposer.Shell.csproj" />
    <Project Path="src/Hexalith.FrontComposer.SourceTools/Hexalith.FrontComposer.SourceTools.csproj" />
    <Project Path="src/Hexalith.FrontComposer.Testing/Hexalith.FrontComposer.Testing.csproj" />
    <Project Path="src/Hexalith.FrontComposer.UI/Hexalith.FrontComposer.UI.csproj">
      <Build Solution="Release|*" Project="false" />
    </Project>
  </Folder>
