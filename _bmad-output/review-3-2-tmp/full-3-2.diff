+using Hexalith.FrontComposer.Shell.State.Navigation;
+
+using Microsoft.AspNetCore.Components;
+using Microsoft.FluentUI.AspNetCore.Components;
+
+namespace Hexalith.FrontComposer.Shell.Components.Layout;
+
+/// <summary>
+/// Hamburger toggle wrapping <c>FluentLayoutHamburger</c> (Story 3-2 D7, D8, D9; AC4, AC5).
+/// Visibility derives from <see cref="FrontComposerNavigationState"/>:
+/// shown whenever the viewport is not <see cref="ViewportTier.Desktop"/> OR the user has
+/// manually collapsed the sidebar at Desktop.
+/// </summary>
+public partial class FcHamburgerToggle : FluxorComponent {
+    private FluentLayoutHamburger? _hamburger;
+
+    [Inject] private IDispatcher Dispatcher { get; set; } = default!;
+
+    [Inject] private IUlidFactory UlidFactory { get; set; } = default!;
+
+    [Inject] private IState<FrontComposerNavigationState> NavState { get; set; } = default!;
+
+    [CascadingParameter] private LayoutHamburgerCoordinator? HamburgerCoordinator { get; set; }
+
+    /// <summary>
+    /// Computed visibility: shown when viewport is non-Desktop OR user manually collapsed at Desktop.
+    /// Internal hook for bUnit assertions (<c>FcHamburgerToggleTests</c>).
+    /// </summary>
+    internal bool IsVisibleForTest => IsVisible;
+
+    protected override void OnAfterRender(bool firstRender) {
+        base.OnAfterRender(firstRender);
+        HamburgerCoordinator?.Register(_hamburger);
+    }
+
+    private bool IsVisible
+        => NavState.Value.CurrentViewport != ViewportTier.Desktop || NavState.Value.SidebarCollapsed;
+
+    /// <summary>
+    /// Test hook exposing the private handler so
+    /// <c>FcHamburgerToggleTests.ManualToggleAtDesktopDispatchesSidebarToggled</c> can invoke the
+    /// FluentLayoutHamburger <c>OnOpened</c> callback without driving the underlying JS event.
+    /// </summary>
+    /// <param name="opened">Whether the drawer was opened (true) or closed (false).</param>
+    internal void OnHamburgerOpenedForTest(bool opened) {
+        if (opened) {
+            OnHamburgerOpened();
+        }
+    }
+
+    private void OnHamburgerOpened() {
+        // D9: manual toggle at Desktop flips SidebarCollapsed. Non-Desktop tiers rely on
+        // FluentLayoutHamburger's own drawer behavior — no additional dispatch needed.
+        if (NavState.Value.CurrentViewport == ViewportTier.Desktop) {
+            Dispatcher.Dispatch(new SidebarToggledAction(UlidFactory.NewUlid()));
+        }
+    }
+}
