diff --git a/src/Hexalith.FrontComposer.Shell/Components/Layout/LayoutHamburgerCoordinator.cs b/src/Hexalith.FrontComposer.Shell/Components/Layout/LayoutHamburgerCoordinator.cs
new file mode 100644
