+        FrontComposerCommandPaletteState closed = InitialState(isOpen: false);
+
+        FrontComposerCommandPaletteState next = CommandPaletteReducers.ReducePaletteResultsComputed(
+            closed,
+            new PaletteResultsComputedAction("cou", results));
