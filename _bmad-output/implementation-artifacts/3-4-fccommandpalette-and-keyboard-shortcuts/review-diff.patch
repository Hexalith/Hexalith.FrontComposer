+                    _restoreBodyFocusOnDispose = ShouldRestoreBodyFocusOnDispose(result);
+                    _explicitlyClosed = true;
+                    if (Dialog is not null)
+                    {
+                        await Dialog.CloseAsync();
+                    }
+                }
