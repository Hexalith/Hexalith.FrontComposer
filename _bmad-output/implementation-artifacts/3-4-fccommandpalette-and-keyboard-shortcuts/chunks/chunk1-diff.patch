+/* Story 3-4 Task 5.3 — palette dialog body. .fc-sr-only is defined in the Story 3-3 shared
+   stylesheet (FrontComposerShell.razor.css). */
+.fc-palette-root {
+    display: flex;
+    flex-direction: column;
+    gap: calc(var(--fc-spacing-unit, 4px) * 2);
