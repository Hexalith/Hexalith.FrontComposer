+using Hexalith.FrontComposer.Shell.Infrastructure.Tenancy;
+
+using Microsoft.AspNetCore.Authorization;
+using Microsoft.AspNetCore.Http;
+using Microsoft.Extensions.DependencyInjection;
+using Microsoft.Extensions.Logging;
+
+namespace Hexalith.FrontComposer.Shell.Services.Authorization;
+
+public sealed class CommandAuthorizationEvaluator(
+    IServiceProvider serviceProvider,
+    IFrontComposerTenantContextAccessor tenantContextAccessor,
+    ILogger<CommandAuthorizationEvaluator> logger) : ICommandAuthorizationEvaluator {
+    public async Task<CommandAuthorizationDecision> EvaluateAsync(
+        CommandAuthorizationRequest request,
+        CancellationToken cancellationToken = default) {
+        ArgumentNullException.ThrowIfNull(request);
+        string correlationId = Guid.NewGuid().ToString("N");
+
+        if (string.IsNullOrWhiteSpace(request.PolicyName)) {
+            return CommandAuthorizationDecision.Allowed(correlationId, CommandAuthorizationReason.NoPolicy);
+        }
+
+        if (cancellationToken.IsCancellationRequested) {
+            return CommandAuthorizationDecision.Blocked(CommandAuthorizationReason.Canceled, correlationId);
+        }
+
+        IAuthorizationService? authorizationService = serviceProvider.GetService<IAuthorizationService>();
+        if (authorizationService is null) {
+            LogBlocked(request, CommandAuthorizationReason.MissingService, correlationId);
+            return CommandAuthorizationDecision.Blocked(CommandAuthorizationReason.MissingService, correlationId);
+        }
+
+        IHttpContextAccessor? http = serviceProvider.GetService<IHttpContextAccessor>();
+        System.Security.Claims.ClaimsPrincipal? user = http?.HttpContext?.User;
+        if (user?.Identity?.IsAuthenticated != true) {
+            LogBlocked(request, CommandAuthorizationReason.Unauthenticated, correlationId);
+            return CommandAuthorizationDecision.Blocked(CommandAuthorizationReason.Unauthenticated, correlationId);
+        }
+
+        TenantContextResult tenant = tenantContextAccessor.TryGetContext(operationKind: "command-authorization");
+        if (!tenant.Succeeded) {
+            LogBlocked(request, CommandAuthorizationReason.StaleTenantContext, tenant.CorrelationId);
+            return CommandAuthorizationDecision.Blocked(CommandAuthorizationReason.StaleTenantContext, tenant.CorrelationId);
+        }
+
+        var resource = new CommandAuthorizationResource(
+            request.CommandType,
+            request.PolicyName.Trim(),
+            request.BoundedContext,
+            request.DisplayLabel,
+            request.SourceSurface,
+            tenant.Context);
+
+        try {
+            AuthorizationResult result = await authorizationService
+                .AuthorizeAsync(user, resource, resource.PolicyName)
+                .ConfigureAwait(false);
+
+            if (result.Succeeded) {
+                return CommandAuthorizationDecision.Allowed(correlationId);
+            }
+
+            LogBlocked(request, CommandAuthorizationReason.Denied, correlationId);
+            return new CommandAuthorizationDecision(
+                CommandAuthorizationDecisionKind.Denied,
+                CommandAuthorizationReason.Denied,
+                correlationId);
+        }
+        catch (OperationCanceledException) {
+            LogBlocked(request, CommandAuthorizationReason.Canceled, correlationId);
+            return CommandAuthorizationDecision.Blocked(CommandAuthorizationReason.Canceled, correlationId);
+        }
+        catch (InvalidOperationException ex) {
+            logger.LogWarning(
+                ex,
+                "Command authorization failed closed. Reason={Reason} CommandType={CommandType} PolicyName={PolicyName} CorrelationId={CorrelationId}",
+                CommandAuthorizationReason.MissingPolicy,
+                request.CommandType.FullName ?? request.CommandType.Name,
+                request.PolicyName.Trim(),
+                correlationId);
+            return CommandAuthorizationDecision.Blocked(CommandAuthorizationReason.MissingPolicy, correlationId);
+        }
+        catch (Exception ex) when (ex is not OutOfMemoryException) {
+            logger.LogWarning(
+                ex,
+                "Command authorization failed closed. Reason={Reason} CommandType={CommandType} PolicyName={PolicyName} CorrelationId={CorrelationId}",
+                CommandAuthorizationReason.HandlerFailed,
+                request.CommandType.FullName ?? request.CommandType.Name,
+                request.PolicyName.Trim(),
+                correlationId);
+            return CommandAuthorizationDecision.Blocked(CommandAuthorizationReason.HandlerFailed, correlationId);
+        }
+    }
+
+    private void LogBlocked(CommandAuthorizationRequest request, CommandAuthorizationReason reason, string correlationId) {
+        logwarning: in the working copy of 'src/Hexalith.FrontComposer.Shell/Services/Authorization/FrontComposerAuthorizationPolicyCatalogValidator.cs', LF will be replaced by CRLF the next time Git touches it
warning: in the working copy of 'src/Hexalith.FrontComposer.Shell/Services/Authorization/ICommandAuthorizationEvaluator.cs', LF will be replaced by CRLF the next time Git touches it
ger.LogWarning(
+            "Command authorization blocked. Reason={Reason} CommandType={CommandType} PolicyName={PolicyName} CorrelationId={CorrelationId}",
+            reason,
+            request.CommandType.FullName ?? request.CommandType.Name,
+            string.IsNullOrWhiteSpace(request.PolicyName) ? "<none>" : request.PolicyName.Trim(),
+            correlationId);
+    }
