+def release_definition_fingerprints(root: pathlib.Path) -> dict[str, str]:
+    fingerprints: dict[str, str] = {}
+    for name in RELEASE_DEFINITION_FILES:
+        path = root / name
+        fingerprints[name] = sha256_file(path) if path.exists() else "missing"
+    return fingerprints
