+        int submittedIndex = source.IndexOf(".SubmittedAction", StringComparison.Ordinal);
+        authIndex.ShouldBeGreaterThan(0);
+        authIndex.ShouldBeLessThan(beforeSubmitIndex);
+        authIndex.ShouldBeLessThan(submittedIndex);
