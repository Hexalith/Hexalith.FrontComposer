diff --git a/src/Hexalith.FrontComposer.Mcp/Rendering/McpMarkdownProjectionRenderer.cs b/src/Hexalith.FrontComposer.Mcp/Rendering/McpMarkdownProjectionRenderer.cs
new file mode 100644
