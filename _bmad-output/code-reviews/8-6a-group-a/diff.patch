+    private static void ValidateAggregateIntegrity(
+        IReadOnlyList<McpManifest> manifests,
+        IReadOnlyList<SchemaFingerprint> corpusFingerprints) {
+        // 8-6a review H7: a manifest that ships a fingerprint but stamps a non-canonical-JSON
+        // algorithm is an inconsistent claim — the canonical aggregate algorithm is fixed at
+        // Sha256CanonicalJsonV1 by D17/AC7. Fail closed in that case. Manifests with no
+        // fingerprint at all (test/legacy scenarios where integrity isn't claimed) are skipped.
+        // When fingerprints are claimed, compare them against the genuine runtime aggregate across
+        // all loaded manifests and corpus fingerprints.
+        SchemaFingerprint?[] claimedFingerprints = [.. manifests.Select(m => m.Fingerprint).Where(f => f is not null)];
+        foreach (SchemaFingerprint manifestFingerprint in claimedFingerprints.Cast<SchemaFingerprint>()) {
+            if (!string.Equals(manifestFingerprint.AlgorithmId, SchemaFingerprintAlgorithm.Sha256CanonicalJsonV1, StringComparison.Ordinal)) {
+                throw new FrontComposerMcpException(FrontComposerMcpFailureCategory.SchemaIntegrityMismatch);
+            }
+        }
+
+        if (claimedFingerprints.Length == 0) {
+            return;
+        }
+
+        SchemaFingerprint computed = FrontComposerMcpRuntimeManifestAggregator.Compute(manifests, corpusFingerprints);
+        foreach (SchemaFingerprint manifestFingerprint in claimedFingerprints.Cast<SchemaFingerprint>()) {
+            if (!string.Equals(manifestFingerprint.Value, computed.Value, StringComparison.Ordinal)) {
+                throw new FrontComposerMcpException(FrontComposerMcpFailureCategory.SchemaIntegrityMismatch);
+            }
+        }
+    }
