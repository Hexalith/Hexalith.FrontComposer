+    private static int CountOccurrences(string source, string needle) {
+        int count = 0;
+        int pos = 0;
+        while ((pos = source.IndexOf(needle, pos, StringComparison.OrdinalIgnoreCase)) != -1) {
+            count++;
+            pos += needle.Length;
+        }
+
+        return count;
