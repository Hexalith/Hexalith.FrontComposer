+            .Add(p => p.ColumnCount, 3)
+            .Add(p => p.RowCount, 2));
+
+        // Header row + 2 body rows = 3 rows with fc-projection-skeleton-row class.
+        int rowOccurrences = CountOccurrences(cut.Markup, "fc-projection-skeleton-row");
