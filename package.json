{
  "name": "hexalith-frontcomposer",
  "version": "0.0.0",
  "private": true,
  "description": "semantic-release configuration for Hexalith.FrontComposer",
  "scripts": {
    "prepare": "husky",
    "test:e2e": "npm --prefix tests/e2e test",
    "test:e2e:install": "npm --prefix tests/e2e install && npm --prefix tests/e2e run install:browsers",
    "test:e2e:a11y": "npm --prefix tests/e2e run test:a11y",
    "test:e2e:visual": "npm --prefix tests/e2e run test:visual",
    "test:e2e:visual:update": "npm --prefix tests/e2e run test:visual:update",
    "test:e2e:ui": "npm --prefix tests/e2e run test:ui",
    "test:e2e:report": "npm --prefix tests/e2e run report",
    "test:dotnet": "dotnet test"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.1.0",
    "@commitlint/config-conventional": "^21.1.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/exec": "^7.1.0",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.8",
    "@semantic-release/release-notes-generator": "^14.1.1",
    "husky": "^9.1.7",
    "semantic-release": "^25.0.5"
  }
}
