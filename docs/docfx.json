{
  "$schema": "https://raw.githubusercontent.com/dotnet/docfx/main/schemas/docfx.schema.json",
  "metadata": [
    {
      "src": [
        {
          "src": "..",
          "files": [
            "src/Hexalith.FrontComposer.Contracts/bin/Release/net10.0/Hexalith.FrontComposer.Contracts.dll",
            "src/Hexalith.FrontComposer.Shell/bin/Release/net10.0/Hexalith.FrontComposer.Shell.dll",
            "src/Hexalith.FrontComposer.SourceTools/bin/Release/netstandard2.0/Hexalith.FrontComposer.SourceTools.dll",
            "src/Hexalith.FrontComposer.Mcp/bin/Release/net10.0/Hexalith.FrontComposer.Mcp.dll"
          ]
        }
      ],
      "dest": "reference/api",
      "disableGitFeatures": true,
      "disableDefaultFilter": false
    }
  ],
  "build": {
    "content": [
      {
        "files": [
          "index.md",
          "toc.yml",
          "tutorials/**.md",
          "how-to/**.md",
          "reference/**.md",
          "concepts/**.md",
          "diagnostics/HFC*.md",
          "migrations/**.md"
        ]
      },
      {
        "files": [
          "reference/api/**.yml"
        ]
      }
    ],
    "resource": [
      {
        "files": [
          "assets/**"
        ]
      }
    ],
    "dest": "_site",
    "globalMetadata": {
      "_appTitle": "Hexalith FrontComposer",
      "_disableContribution": true
    },
    "template": [
      "default",
      "modern"
    ],
    "xref": [],
    "warningsAsErrors": true
  }
}
