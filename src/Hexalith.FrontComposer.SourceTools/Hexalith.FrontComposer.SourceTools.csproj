<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>netstandard2.0</TargetFramework>
    <IsRoslynComponent>true</IsRoslynComponent>
    <EnforceExtendedAnalyzerRules>true</EnforceExtendedAnalyzerRules>
    <IsPackable>false</IsPackable>
    <!-- RS2002: HFC1010 is intentionally reserved as a table row in AnalyzerReleases.Unshipped.md
         without a DiagnosticDescriptor field (Story 1.8 AC4). Implementation requires an analyzer
         (generators see current state, not diffs) — deferred. See docs/hot-reload-guide.md.
         WARNING — this suppression is project-wide: a future DiagnosticDescriptor added without
         the corresponding AnalyzerReleases.Unshipped.md row (or vice-versa) will NOT produce a
         build warning. When adding a new diagnostic, manually cross-check both files. This gap
         is tracked for a targeted test in deferred-work.md ("RS2002 guard test"). -->
    <NoWarn>$(NoWarn);RS2002</NoWarn>
  </PropertyGroup>
  <ItemGroup>
    <ProjectReference Include="..\Hexalith.FrontComposer.Contracts\Hexalith.FrontComposer.Contracts.csproj" />
    <PackageReference Include="Microsoft.CodeAnalysis.CSharp" PrivateAssets="all" />
  </ItemGroup>
  <ItemGroup>
    <InternalsVisibleTo Include="Hexalith.FrontComposer.SourceTools.Tests" />
  </ItemGroup>
  <ItemGroup>
    <AdditionalFiles Include="AnalyzerReleases.Shipped.md" />
    <AdditionalFiles Include="AnalyzerReleases.Unshipped.md" />
  </ItemGroup>
</Project>
