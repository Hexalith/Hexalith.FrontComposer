@namespace Hexalith.FrontComposer.Shell.Components.Lifecycle
@using Hexalith.FrontComposer.Contracts.Communication
@using Hexalith.FrontComposer.Contracts.Lifecycle
@using Microsoft.AspNetCore.Components
@using Microsoft.FluentUI.AspNetCore.Components

@* Review 2026-04-17 P3 — CascadingValue wired so FcFormAbandonmentGuard can yield during
   wrapper-initiated Start-over navigation. Today `OnStartOverClicked` uses forceLoad:true
   which bypasses NavigationLock anyway, but the cascade is correct defense-in-depth. *@
<CascadingValue Name="WrapperInitiatedNavigation" Value="_wrapperInitiatedNavigation" IsFixed="false">
<div class="fc-lifecycle-wrapper @PulseClass()"
     data-testid="@LifecycleTestId"
     data-lifecycle-state="@LifecycleStateAttribute">
    @ChildContent

    @if (!string.IsNullOrEmpty(Announcement)) {
        <div role="@AriaRole" aria-live="@AriaLive" data-fc-phase="@DataPhase" class="fc-lifecycle-live">
            @Announcement
        </div>
    }

    @if (_state.Current is CommandLifecycleState.Syncing
            && _state.TimerPhase is LifecycleTimerPhase.StillSyncing) {
        <FluentBadge Appearance="BadgeAppearance.Filled"
                     Color="BadgeColor.Informative"
                     class="fc-lifecycle-still-syncing">Still syncing…</FluentBadge>
    }

    @if (_state.Current is CommandLifecycleState.Acknowledged) {
        <FluentBadge Appearance="BadgeAppearance.Filled"
                     Color="BadgeColor.Informative"
                     class="fc-lifecycle-acknowledged"
                     data-testid="fc-acknowledged-badge">Acknowledged</FluentBadge>

        <FluentMessageBar Intent="MessageBarIntent.Info"
                         Title="Submission acknowledged"
                         AllowDismiss="false"
                         data-testid="fc-acknowledged">
            <ChildContent>
                The command was accepted and is waiting for confirmation.
            </ChildContent>
        </FluentMessageBar>
    }

    @if (_state.Current is CommandLifecycleState.Syncing
            && _state.TimerPhase is LifecycleTimerPhase.ActionPrompt) {
        <FluentMessageBar Intent="MessageBarIntent.Warning"
                         Title="@ActionPromptTitle"
                         AllowDismiss="false"
                         data-testid="fc-action-prompt">
            <ChildContent>
                You can wait, or start over from a fresh page.
            </ChildContent>
            <ActionsTemplate>
                <FluentButton Appearance="ButtonAppearance.Primary"
                              Size="ButtonSize.Small"
                              data-testid="fc-refresh-action"
                              OnClick="OnStartOverClicked">Start over</FluentButton>
            </ActionsTemplate>
        </FluentMessageBar>
    }

    @if (_state.Current is CommandLifecycleState.Confirmed && !_state.IsIdempotent) {
        <FluentMessageBar Intent="MessageBarIntent.Success"
                         Title="Submission confirmed"
                         AllowDismiss="true"
                         data-testid="fc-confirmed">
        </FluentMessageBar>
    }

    @if (_state.Current is CommandLifecycleState.Confirmed && _state.IsIdempotent) {
        <FluentMessageBar Intent="MessageBarIntent.Info"
                         Title="Already confirmed"
                         AllowDismiss="true"
                         data-testid="fc-idempotent">
            <ChildContent>
                @(IdempotentInfoMessage ?? "This was already confirmed — no action needed.")
            </ChildContent>
        </FluentMessageBar>
    }

    @if (_state.Current is CommandLifecycleState.Rejected) {
        <FluentMessageBar Intent="MessageBarIntent.Error"
                         Title="@ResolveRejectionTitle()"
                         AllowDismiss="true"
                         data-testid="fc-rejected">
            <ChildContent>
                @(RejectionMessage ?? "The command was rejected. Please review your input and try again.")
                @if (RejectionDetails is not null) {
                    <dl class="fc-rejection-details">
                        <div>
                            <dt>Error code</dt>
                            <dd>@RejectionDetails.ErrorCode</dd>
                        </div>
                        <div>
                            <dt>Reason category</dt>
                            <dd>@RejectionDetails.ReasonCategory</dd>
                        </div>
                        <div>
                            <dt>Suggested action</dt>
                            <dd>@RejectionDetails.SuggestedAction</dd>
                        </div>
                        <div>
                            <dt>Docs code</dt>
                            <dd>@RejectionDetails.DocsCode</dd>
                        </div>
                    </dl>
                }
            </ChildContent>
        </FluentMessageBar>
    }
</div>
</CascadingValue>

@code {
    private string ResolveRejectionTitle()
        // Review 2026-04-17 P14 — IsNullOrEmpty already narrows to non-null; no `!` needed.
        => string.IsNullOrEmpty(RejectionTitle) ? "Submission rejected" : RejectionTitle;

    private string? LifecycleTestId =>
        string.IsNullOrWhiteSpace(CommandId) ? null : $"fc-lifecycle-{CommandId}";

    private string LifecycleStateAttribute => _state.Current switch {
        CommandLifecycleState.Submitting => "submitting",
        CommandLifecycleState.Acknowledged => "acknowledged",
        CommandLifecycleState.Syncing => "syncing",
        CommandLifecycleState.Confirmed => "confirmed",
        CommandLifecycleState.Rejected => "rejected",
        _ => "idle",
    };

    private string ActionPromptTitle =>
        _state.Current is CommandLifecycleState.Syncing
            && _state.TimerPhase is LifecycleTimerPhase.ActionPrompt
            && _projectionConnectionSnapshot.IsDisconnected
                ? "Connection lost -- unable to confirm sync status"
                : "Action needed: the system hasn't confirmed your submission";

    private string PulseClass() =>
        _state.Current is CommandLifecycleState.Syncing
            && _state.TimerPhase is LifecycleTimerPhase.Pulse
                ? "fc-lifecycle-pulse"
                : string.Empty;

    private string Announcement => _state.Current switch {
        CommandLifecycleState.Submitting => "Submitting…",
        CommandLifecycleState.Acknowledged => "Acknowledged",
        CommandLifecycleState.Syncing when _state.TimerPhase is LifecycleTimerPhase.StillSyncing => "Still syncing…",
        CommandLifecycleState.Syncing when _state.TimerPhase is LifecycleTimerPhase.ActionPrompt && _projectionConnectionSnapshot.IsDisconnected => "Connection lost -- unable to confirm sync status",
        CommandLifecycleState.Syncing when _state.TimerPhase is LifecycleTimerPhase.ActionPrompt => "The system hasn't confirmed your submission. You can wait or start over.",
        // Review 2026-04-17 P12 — when an adopter supplies IdempotentInfoMessage, screen readers
        // announce that copy rather than the hardcoded "Already confirmed" (matches the visible body).
        CommandLifecycleState.Confirmed when _state.IsIdempotent => IdempotentInfoMessage ?? "Already confirmed",
        CommandLifecycleState.Confirmed => "Submission confirmed",
        CommandLifecycleState.Rejected => "Submission rejected",
        _ => string.Empty,
    };

    private string AriaRole => _state.Current switch {
        CommandLifecycleState.Rejected => "alert",
        CommandLifecycleState.Syncing when _state.TimerPhase is LifecycleTimerPhase.ActionPrompt => "alert",
        _ => "status",
    };

    private string AriaLive => _state.Current switch {
        CommandLifecycleState.Rejected => "assertive",
        CommandLifecycleState.Syncing when _state.TimerPhase is LifecycleTimerPhase.ActionPrompt => "assertive",
        _ => "polite",
    };

    private string DataPhase => _state.Current switch {
        CommandLifecycleState.Submitting => "submitting",
        CommandLifecycleState.Acknowledged => "acknowledged",
        CommandLifecycleState.Syncing when _state.TimerPhase is LifecycleTimerPhase.StillSyncing => "still-syncing",
        CommandLifecycleState.Syncing when _state.TimerPhase is LifecycleTimerPhase.ActionPrompt => "action-prompt",
        CommandLifecycleState.Confirmed when _state.IsIdempotent => "confirmed-idempotent",
        CommandLifecycleState.Confirmed => "confirmed",
        CommandLifecycleState.Rejected => "rejected",
        _ => "idle",
    };
}
