@namespace Hexalith.FrontComposer.Shell.Components.DataGrid
@using Microsoft.FluentUI.AspNetCore.Components

@* Story 4-5 AC8 / D19 / Review-revision — breadcrumb banner shown above the FluentDataGrid when
   the user has an expanded row that the current filter predicate has hidden from state.Items.
   Per V4 Path B (story Dev Agent Record verification log), the host view computes
   IsHiddenByFilter (it has typed access to state.Items + _expandedItem) and passes the bool
   to this banner — the banner does not need to recompute the filter predicate itself. *@

@if (IsHiddenByFilter) {
    <div role="status"
         aria-live="polite"
         class="fc-expanded-row-hidden-banner"
         data-testid="fc-expanded-row-hidden-banner">
        <span class="fc-expanded-row-hidden-banner-text">@_bannerMessage</span>
        <FluentButton Appearance="ButtonAppearance.Subtle"
                      OnClick="@OnClearFilterClickedAsync"
                      data-testid="fc-expanded-row-hidden-banner-clear">
            @Localizer["ExpandedRowHiddenByFilterBannerClearLink"].Value
        </FluentButton>
    </div>
}
