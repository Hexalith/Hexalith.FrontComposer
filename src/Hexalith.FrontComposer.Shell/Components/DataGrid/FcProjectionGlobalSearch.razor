@namespace Hexalith.FrontComposer.Shell.Components.DataGrid
@using Microsoft.FluentUI.AspNetCore.Components

@* Story 4-3 T1.3 / D6 / AC4 — optional global search input with 300ms TimeProvider debounce. *@

<label class="fc-sr-only" for="@_inputId">@_ariaLabel</label>
<FluentTextInput Id="@_inputId"
                 Value="@_value"
                 ValueChanged="@OnValueChangedAsync"
                 TextInputType="TextInputType.Search"
                 Placeholder="@_placeholder"
                 data-testid="fc-global-search" />
