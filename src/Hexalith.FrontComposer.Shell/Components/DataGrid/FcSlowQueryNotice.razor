@namespace Hexalith.FrontComposer.Shell.Components.DataGrid
@using Microsoft.FluentUI.AspNetCore.Components

@* Story 4-4 T1.2 / D8 / D11 / AC3 — auto-dismissing Info banner for slow-query signals. *@

@if (_visible) {
    <FluentMessageBar Intent="MessageBarIntent.Info"
                      AllowDismiss="false"
                      data-testid="fc-slow-query-notice"
                      aria-live="polite">
        @Localizer["SlowQueryNoticeMessage"].Value
    </FluentMessageBar>
}
