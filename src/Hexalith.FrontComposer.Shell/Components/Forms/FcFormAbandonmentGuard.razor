@namespace Hexalith.FrontComposer.Shell.Components.Forms
@using Microsoft.AspNetCore.Components
@using Microsoft.AspNetCore.Components.Routing
@using Microsoft.AspNetCore.Components.Web
@using Microsoft.FluentUI.AspNetCore.Components

<NavigationLock OnBeforeInternalNavigation="HandleNavigationChangingAsync" />

@if (_showingWarning) {
    <FluentMessageBar Intent="MessageBarIntent.Warning"
                      Title="You have unsaved input."
                      AllowDismiss="false"
                      data-testid="fc-form-abandonment-warning">
        <ChildContent>
            Leaving now discards what you've entered.
        </ChildContent>
        <ActionsTemplate>
            <FluentButton Appearance="ButtonAppearance.Primary"
                          AutoFocus="true"
                          OnClick="OnStayClickedAsync"
                          @onkeydown="HandleBarKeyDownAsync"
                          data-testid="fc-form-abandonment-stay">Stay on form</FluentButton>
            <FluentButton Appearance="ButtonAppearance.Outline"
                          OnClick="OnLeaveClickedAsync"
                          data-testid="fc-form-abandonment-leave">Leave anyway</FluentButton>
        </ActionsTemplate>
    </FluentMessageBar>
}

@ChildContent
