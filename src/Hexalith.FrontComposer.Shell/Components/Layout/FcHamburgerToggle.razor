@namespace Hexalith.FrontComposer.Shell.Components.Layout
@using Hexalith.FrontComposer.Shell.Components.Icons
@using Hexalith.FrontComposer.Shell.Resources
@using Hexalith.FrontComposer.Shell.State.Navigation
@using Microsoft.Extensions.Localization
@using Microsoft.FluentUI.AspNetCore.Components
@inherits Fluxor.Blazor.Web.Components.FluxorComponent
@inject IStringLocalizer<FcShellResources> Localizer

@* Always-visible navigation hamburger. Supersedes the earlier D9 "no Desktop hamburger" decision
   (2026-06 UX request — match the Fluent reference shell where a hamburger toggles the menu at every
   width). At Desktop the hamburger is a subtle FluentButton that toggles SidebarCollapsed (72px
   labeled rail <-> 48px icon-only rail) via SidebarToggledAction — the width/rail swap (FrontComposerShell
   NavigationWidth + FrontComposerNavigation rail mode) and persistence
   (NavigationEffects.HandleSidebarToggled) are already wired to that state. At CompactDesktop /
   Tablet / Phone it stays the FluentLayoutHamburger that opens the responsive navigation drawer. *@

@* Plain HTML root so the scoped FcHamburgerToggle.razor.css scope id (b-xxxxx) lands on a real
   element and the `::deep svg` fill override actually applies. A Fluent component root would NOT
   get the scope id splatted onto its rendered DOM, leaving the stylesheet inert. *@
<div class="fc-hamburger-toggle">
    @if (IsDesktop)
    {
        <FluentButton Appearance="@ButtonAppearance.Subtle"
                      Title="@Localizer["HamburgerToggleAriaLabel"].Value"
                      role="button"
                      aria-label="@Localizer["HamburgerToggleAriaLabel"].Value"
                      data-testid="fc-hamburger-toggle"
                      OnClick="ToggleSidebar">
            <FluentIcon Value="@FcFluentIcons.Navigation20()" Color="Color.Primary" />
        </FluentButton>
    }
    else
    {
        <FluentLayoutHamburger Visible="true"
                               @ref="_hamburger"
                               IconTitle="@Localizer["HamburgerToggleAriaLabel"].Value"
                               role="button"
                               data-testid="fc-hamburger-toggle" />
    }
</div>
