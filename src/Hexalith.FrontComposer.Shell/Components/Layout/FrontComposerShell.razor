@namespace Hexalith.FrontComposer.Shell.Components.Layout
@using Microsoft.AspNetCore.Components.Web
@using Microsoft.FluentUI.AspNetCore.Components
@using Hexalith.FrontComposer.Contracts.Registration
@using Hexalith.FrontComposer.Contracts.Rendering
@using Hexalith.FrontComposer.Contracts.Diagnostics
@using Hexalith.FrontComposer.Shell.Components.Diagnostics
@using Hexalith.FrontComposer.Shell.Components.DevMode
@using Hexalith.FrontComposer.Shell.Components.EventStore
@using Hexalith.FrontComposer.Shell.Components.Icons
@using Hexalith.FrontComposer.Shell.Resources
@inherits Fluxor.Blazor.Web.Components.FluxorComponent
@implements IAsyncDisposable
@inject IStringLocalizer<FcShellResources> Localizer

@* Story 3-1 D3 / AC1 — framework-owned shell composition point. Adopters wrap @Body via
   <FrontComposerShell>@Body</FrontComposerShell> in their MainLayout.razor. Story 3-2 additions
   (D10 / D18 / Task 8.3 / Task 8.3a): HeaderCenter slot for breadcrumbs (Story 3-5 fills content),
   Navigation slot auto-populates <FrontComposerNavigation /> when the adopter leaves it null AND
   the registry has ≥1 renderable manifest (ADR-035), FcHamburgerToggle auto-populates HeaderStart
   symmetrically, FcLayoutBreakpointWatcher mounts alongside FcSystemThemeWatcher, skip-to-navigation
   link renders immediately after Story 3-1's SkipToContent link (AC6 / D16). *@

<HeadContent>
    <link rel="stylesheet" href="@ShellStylesheetPath" />
    <link rel="stylesheet" href="@DensityStylesheetPath" />
    <link rel="stylesheet" href="@ProjectionStylesheetPath" />
</HeadContent>

<div class="fc-shell-root" style="--fc-accent-base-color: @AccentColor;" tabindex="0" @ref="_shellRoot"
     @onkeydown="HandleGlobalKeyDown">
    <Fluxor.Blazor.Web.StoreInitializer />
    <a class="fc-skip-link" href="#fc-main-content">@Localizer["SkipToContentLabel"].Value</a>
    @if (HasNavigation)
    {
        <a class="fc-skip-link" href="#fc-nav">@Localizer["SkipToNavigationLabel"].Value</a>
    }

    <CascadingValue Value="_hamburgerCoordinator" IsFixed="true">
    @* FC-LYT (Story 1.2) — cascade the page-layout coordinator so a page's <FcPageLayout> (inside
       @ChildContent) can declare its measure without a shell [Parameter]. IsFixed: the coordinator
       instance is stable; its Mode mutates and the shell re-renders via the Changed subscription. *@
    <CascadingValue Value="_pageLayoutCoordinator" IsFixed="true">
    @* Handoff outcome 1/2 — cascade the content-label coordinator so a page's <FcContentLabel> can
       name #fc-main-content's `main` landmark by its route heading (no orphaned page-level
       aria-labelledby). IsFixed: the coordinator instance is stable; its values mutate and the shell
       re-renders via the Changed subscription. *@
    <CascadingValue Value="_contentLabelCoordinator" IsFixed="true">
        <FluentLayout>
            <FluentLayoutItem Area="@LayoutArea.Header" Height="48px">
                <FluentStack Horizontal="true" VerticalAlignment="VerticalAlignment.Center"
                             HorizontalAlignment="HorizontalAlignment.SpaceBetween"
                             Style="height: 48px; padding: 0 12px; background: var(--colorNeutralBackground2); color: var(--colorNeutralForeground1); border-block-end: 1px solid var(--colorNeutralStroke2);">
                    <FluentStack Horizontal="true" VerticalAlignment="VerticalAlignment.Center"
                                 HorizontalGap="@HeaderStartHorizontalGap">
                        @if (HeaderStart is not null)
                        {
                            @HeaderStart
                        }
                        else
                        {
                            <FcHamburgerToggle />
                        }
                        @if (ShouldRenderHeaderLogo)
                        {
                            <span data-testid="fc-shell-brand-logo" aria-hidden="@HeaderLogoAriaHidden">
                                @if (HeaderLogo is not null)
                                {
                                    @HeaderLogo
                                }
                                else
                                {
                                    <FluentIcon Value="@FcFluentIcons.Apps20()" Color="Color.Primary" />
                                }
                            </span>
                        }
                        <FluentText Size="@Typography.AppTitle.Size" Weight="@Typography.AppTitle.Weight"
                                    As="@Typography.AppTitle.Tag">
                            @ResolvedAppTitle
                        </FluentText>
                        @if (HeaderCenter is not null)
                        {
                            <FluentStack Horizontal="true" VerticalAlignment="VerticalAlignment.Center">
                                @HeaderCenter
                            </FluentStack>
                        }
                    </FluentStack>
                    <FluentStack Horizontal="true" VerticalAlignment="VerticalAlignment.Center" Width="fit-content">
                        <FcThemeToggle />
                        @if (IsDevModeBuild)
                        {
                            <FcDevModeToggleButton />
                        }
                        @if (HeaderEnd is not null)
                        {
                            @HeaderEnd
                        }
                        else
                        {
                            @* Story 3-4 D18 — palette trigger first (primary navigation per UX spec §82), then settings. *@
                            <FcPaletteTriggerButton />
                            <FcSettingsButton />
                        }
                        @* Account avatar (sign in / sign out) — rendered ALWAYS as the right-most header
                           action so it survives adopter HeaderEnd customization, matching the Fluent
                           "account at far right" convention. *@
                        <FcAccountMenu />
                    </FluentStack>
                </FluentStack>
            </FluentLayoutItem>

            @if (HasNavigation && !IsSubCompactDesktopViewport)
            {
                <FluentLayoutItem Area="@LayoutArea.Navigation" Width="@NavigationWidth" data-testid="fc-shell-navigation">
                    <div id="fc-nav" tabindex="-1">
                        @if (Navigation is not null)
                        {
                            @Navigation
                        }
                        else
                        {
                            <FrontComposerNavigation />
                        }
                    </div>
                </FluentLayoutItem>
            }

            <FluentLayoutItem Area="@LayoutArea.Content" Padding="@Padding.All3">
                <FcLayoutBreakpointWatcher />
                <FcSystemThemeWatcher />
                <FcDensityApplier />
                <FcDensityAnnouncer />
                @* FC-LYT (Story 1.2): id + tabindex stay adjacent (skip-link/focus target + locked test
                   substring); the data-fc-page-layout attr + fc-page-layout class are appended after. *@
                @* Handoff outcome 1/2 — the shell's single content `main` landmark. id + tabindex stay
                   adjacent (skip-link/focus target + locked test substring). aria-labelledby / aria-label
                   name the landmark from the route heading (via <FcContentLabel> or the ContentLabelledBy
                   / ContentLabel shell parameters); exactly one is ever emitted, both null by default so
                   the implicit "main" name is the zero-config default. *@
                <div id="fc-main-content" tabindex="-1" role="main"
                     aria-labelledby="@ContentLabelledByValue" aria-label="@ContentLabelValue"
                     data-fc-page-layout="@PageLayoutAttribute" class="@PageLayoutCssClass">
                    <FcProjectionConnectionStatus />
                    <FcPendingCommandSummary />
                    @ChildContent
                </div>
            </FluentLayoutItem>

            <FluentLayoutItem Area="@LayoutArea.Footer">
                <FluentStack VerticalAlignment="VerticalAlignment.Center"
                             Style="padding: 8px 12px; min-height: 36px; background: var(--colorNeutralBackground2); color: var(--colorNeutralForeground2); border-block-start: 1px solid var(--colorNeutralStroke2);">
                    @if (Footer is not null)
                    {
                        @Footer
                    }
                    else
                    {
                        @* Footer text inherits the muted --colorNeutralForeground2 from the frame above.
                           Color.Lightweight is NOT used here: in Fluent UI v5 it maps to
                           --colorNeutralForegroundInverted (white), which is invisible on the neutral
                           light footer surface. *@
                        <FluentText As="TextTag.Span" Size="TextSize.Size200">
                            @Localizer["FooterCopyright", ResolvedAppTitle, DateTime.Now.Year].Value
                        </FluentText>
                    }
                </FluentStack>
            </FluentLayoutItem>
        </FluentLayout>
    </CascadingValue>
    </CascadingValue>
    </CascadingValue>

    <FluentProviders />
    @if (IsDevModeBuild)
    {
        @foreach (CustomizationDiagnostic diagnostic in ContractMismatchDiagnostics)
        {
            <FcCustomizationDiagnosticPanel Diagnostic="@diagnostic" />
        }
        <FcDevModeOverlay />
    }
</div>
