@namespace Hexalith.FrontComposer.Shell.Components.Layout
@using Hexalith.FrontComposer.Contracts.Registration
@using Hexalith.FrontComposer.Shell.Badges
@using Hexalith.FrontComposer.Shell.Resources
@using Hexalith.FrontComposer.Shell.State.CapabilityDiscovery
@using Hexalith.FrontComposer.Shell.State.Navigation
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.Extensions.Localization
@using Microsoft.FluentUI.AspNetCore.Components
@inherits Fluxor.Blazor.Web.Components.FluxorComponent
@inject IFrontComposerRegistry Registry
@inject IStringLocalizer<FcShellResources> Localizer

@* Story 3-2 Task 6 (D1, D2, D7, D9, D11 / AC1, AC3, AC6) — framework-owned sidebar.
   At CompactDesktop OR Desktop + SidebarCollapsed we swap to FcCollapsedNavRail (D7 / D9);
   otherwise we render FluentNav with one FluentNavCategory per manifest whose Projections list
   is non-empty (D1). Commands are excluded. Nav-item routes follow the D2 convention:
   /{boundedContext-lowercase}/{projectionTypeName-kebab-case}.

   Story 3-5 Task 5 (D8 / D12 / D13 / D14 / AC8 / AC9 / AC10) — alongside each projection nav entry
   render a FluentBadge when the IBadgeCountService count > 0, plus a "New" FluentBadge when the
   capabilityId is not in the seen-set AND the projection has data. Click dispatches
   CapabilityVisitedAction synchronously (D13 ordering — reducer wins before navigation). *@

@if (ShouldRenderCollapsedRail())
{
    <FcCollapsedNavRail />
}
else
{
    FrontComposerCapabilityDiscoveryState discovery = DiscoveryState.Value;
    IReadOnlyList<FrontComposerNavEntry> navEntries = Registry.GetNavEntries();

    // Explicit nav entries are rendered as FluentNavItems alongside projection items. Gated entries
    // (RequiredPolicy set) wrap in AuthorizeView; disabled entries render a non-link affordance + reason.
    RenderFragment<FrontComposerNavEntry> navEntryItem = entry =>
        @<FluentNavItem Href="@(entry.Enabled ? entry.Href : null)"
                        Disabled="@(!entry.Enabled)"
                        IconRest="@ResolveNavEntryIcon(entry.Icon)"
                        Tooltip="@(entry.Enabled ? null : entry.DisabledReason)"
                        data-testid="@NavEntryTestId(entry)">
            @entry.Title
            @if (!entry.Enabled && !string.IsNullOrWhiteSpace(entry.DisabledReason))
            {
                <span class="fc-nav-entry__reason" data-testid="@($"{NavEntryTestId(entry)}-reason")">@entry.DisabledReason</span>
            }
        </FluentNavItem>;

    RenderFragment<FrontComposerNavEntry> navEntry = entry =>
        @<text>
            @if (!string.IsNullOrWhiteSpace(entry.RequiredPolicy))
            {
                <AuthorizeView Policy="@entry.RequiredPolicy">
                    <Authorized>@navEntryItem(entry)</Authorized>
                </AuthorizeView>
            }
            else
            {
                @navEntryItem(entry)
            }
        </text>;

    <FluentNav UseIcons="true" data-testid="fc-navigation-full"
               aria-label="@Localizer["NavMenuAriaLabel"].Value">
        @foreach (DomainManifest manifest in Registry.GetManifests())
        {
            List<string> projections = VisibleProjections(manifest, discovery.Counts);
            List<FrontComposerNavEntry> entries = EntriesForContext(navEntries, manifest.BoundedContext);
            @if (projections.Count == 0 && entries.Count == 0)
            {
                continue;
            }

            string bcCapabilityId = CapabilityIds.ForBoundedContext(manifest.BoundedContext);
            int aggregateCount = AggregateBoundedContextCount(manifest, discovery.Counts);
            bool bcShowsNew = !discovery.SeenCapabilities.Contains(bcCapabilityId) && aggregateCount > 0;

            <FluentNavCategory Id="@manifest.BoundedContext"
                               Title="@manifest.Name"
                               Expanded="@(!IsGroupCollapsed(manifest.BoundedContext))"
                               ExpandedChanged="@(value => OnGroupExpandedChanged(manifest.BoundedContext, bcCapabilityId, value))"
                               data-testid="@($"fc-nav-category-{manifest.BoundedContext}")">
                @foreach (string projectionFqn in projections)
                {
                    int count = LookupCount(projectionFqn, discovery.Counts);
                    string projCapabilityId = CapabilityIds.ForProjection(manifest.BoundedContext, projectionFqn);
                    bool projShowsNew = !discovery.SeenCapabilities.Contains(projCapabilityId) && count > 0;

                    <FluentNavItem Href="@BuildRoute(manifest.BoundedContext, projectionFqn)"
                                   OnClick="@(_ => HandleNavItemClicked(manifest.BoundedContext, projCapabilityId))">
                        @ProjectionLabel(projectionFqn)
                        @if (count > 0)
                        {
                            <FluentBadge Appearance="@BadgeAppearance.Filled"
                                         Color="@BadgeColor.Brand"
                                         data-testid="@($"fc-nav-badge-{manifest.BoundedContext}-{ProjectionLabel(projectionFqn)}")">@count</FluentBadge>
                        }
                        @if (projShowsNew)
                        {
                            <FluentBadge Appearance="@BadgeAppearance.Tint"
                                         Color="@BadgeColor.Informative"
                                         data-testid="@($"fc-nav-new-{manifest.BoundedContext}-{ProjectionLabel(projectionFqn)}")">
                                @Localizer["NewCapabilityBadgeText"].Value
                            </FluentBadge>
                        }
                    </FluentNavItem>
                }
                @foreach (FrontComposerNavEntry entry in entries)
                {
                    @navEntry(entry)
                }
                @if (bcShowsNew)
                {
                    <FluentBadge Appearance="@BadgeAppearance.Tint"
                                 Color="@BadgeColor.Informative"
                                 data-testid="@($"fc-nav-bc-new-{manifest.BoundedContext}")">
                        @Localizer["NewCapabilityBadgeText"].Value
                    </FluentBadge>
                }
            </FluentNavCategory>
        }
        @foreach (string orphanBc in OrphanEntryContexts(navEntries))
        {
            <FluentNavCategory Id="@orphanBc"
                               Title="@orphanBc"
                               Expanded="@(!IsGroupCollapsed(orphanBc))"
                               ExpandedChanged="@(value => OnGroupExpandedChanged(orphanBc, CapabilityIds.ForBoundedContext(orphanBc), value))"
                               data-testid="@($"fc-nav-category-{orphanBc}")">
                @foreach (FrontComposerNavEntry entry in EntriesForContext(navEntries, orphanBc))
                {
                    @navEntry(entry)
                }
            </FluentNavCategory>
        }
    </FluentNav>
}
