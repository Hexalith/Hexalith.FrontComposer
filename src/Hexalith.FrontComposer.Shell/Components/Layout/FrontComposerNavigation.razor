@namespace Hexalith.FrontComposer.Shell.Components.Layout
@using Hexalith.FrontComposer.Contracts.Registration
@using Hexalith.FrontComposer.Shell.Badges
@using Hexalith.FrontComposer.Shell.Resources
@using Hexalith.FrontComposer.Shell.State.CapabilityDiscovery
@using Hexalith.FrontComposer.Shell.State.Navigation
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.Extensions.Localization
@using Microsoft.FluentUI.AspNetCore.Components
@inherits Fluxor.Blazor.Web.Components.FluxorComponent
@inject IFrontComposerRegistry Registry
@inject IStringLocalizer<FcShellResources> Localizer

@{
    FrontComposerCapabilityDiscoveryState discovery = DiscoveryState.Value;
    IReadOnlyList<FrontComposerNavEntry> navEntries = Registry.GetNavEntries();
    bool iconOnly = ShouldRenderIconOnlyRail();

    RecomputeActiveNavHref(discovery, navEntries);

    RenderFragment<FrontComposerNavEntry> navEntryItem = entry =>
        @<FluentMenuItem Role="@MenuItemRole.MenuItem"
                         Disabled="@(!entry.Enabled)"
                         IconStart="@ResolveNavEntryIcon(entry.Icon, IsHrefActive(entry.Href))"
                         OnClick="@(_ => HandleNavEntryMenuItemClicked(entry))"
                         data-testid="@NavEntryTestId(entry)"
                         data-href="@(entry.Enabled ? entry.Href : null)"
                         aria-current="@(IsHrefActive(entry.Href) ? "page" : null)">
            <FluentStack Orientation="Orientation.Vertical" VerticalGap="2px">
                <FluentText>@LocalizeEntryTitle(entry)</FluentText>
                @if (!entry.Enabled && !string.IsNullOrWhiteSpace(entry.DisabledReason))
                {
                    <FluentText Size="TextSize.Size200"
                                Color="Color.Lightweight"
                                data-testid="@($"{NavEntryTestId(entry)}-reason")">@LocalizeEntryReason(entry)</FluentText>
                }
            </FluentStack>
        </FluentMenuItem>;

    RenderFragment<FrontComposerNavEntry> navEntry = entry =>
        @<text>
            @if (!string.IsNullOrWhiteSpace(entry.RequiredPolicy))
            {
                <AuthorizeView Policy="@entry.RequiredPolicy">
                    <Authorized>@navEntryItem(entry)</Authorized>
                </AuthorizeView>
            }
            else
            {
                @navEntryItem(entry)
            }
        </text>;
}

@* Story (cc-2026-06-28): the rail root is a plain <div> so Blazor CSS isolation lands the scope
   id on it. Previously the root was a <FluentStack>, whose rendered div never received the scope
   attribute, leaving the entire FrontComposerNavigation.razor.css inert (no rail divider/padding,
   no active accent indicator, dead label rule). The div revives the scoped rules; the inner
   FluentStack keeps the vertical stack/gap so Fluent still owns the layout primitive. *@
<div class="@RailClass"
     style="width: @RailWidth"
     data-testid="fc-navigation-rail"
     data-rail-width="@RailWidthValue"
     role="navigation"
     aria-label="@Localizer["NavMenuAriaLabel"].Value">
<FluentStack Orientation="Orientation.Vertical"
             VerticalGap="4px"
             HorizontalAlignment="HorizontalAlignment.Center"
             Width="100%">
    @foreach (DomainManifest manifest in Registry.GetManifests())
    {
        List<string> projections = VisibleProjections(manifest, discovery.Counts);
        List<FrontComposerNavEntry> entries = EntriesForContext(navEntries, manifest.BoundedContext);
        @if (projections.Count == 0 && entries.Count == 0)
        {
            continue;
        }

        string anchorId = RailAnchorId(manifest.BoundedContext);
        string bcCapabilityId = CapabilityIds.ForBoundedContext(manifest.BoundedContext);
        int aggregateCount = AggregateBoundedContextCount(manifest, discovery.Counts);
        bool bcShowsNew = !discovery.SeenCapabilities.Contains(bcCapabilityId) && aggregateCount > 0;
        bool activeContext = IsContextActive(manifest.BoundedContext, projections, entries);

        <FluentButton id="@anchorId"
                      Appearance="@ButtonAppearance.Subtle"
                      Class="@ContextTileClass(activeContext)"
                      Title="@(iconOnly ? LocalizeManifestName(manifest) : null)"
                      aria-label="@(iconOnly ? LocalizeManifestName(manifest) : null)"
                      aria-current="@(activeContext ? "page" : null)"
                      data-testid="@($"fc-nav-context-{manifest.BoundedContext}")"
                      data-active="@activeContext"
                      tabindex="0"
                      OnClick="@(_ => HandleContextTileActivated(manifest.BoundedContext))">
            <FluentStack Class="fc-navigation-rail__tile-content"
                         Orientation="Orientation.Vertical"
                         HorizontalAlignment="HorizontalAlignment.Center"
                         VerticalAlignment="VerticalAlignment.Center"
                         VerticalGap="2px"
                         Width="100%">
                <FluentIcon Value="@ResolveNavEntryIcon(manifest.Icon, activeContext)" Color="Color.Primary" />
                @if (!iconOnly)
                {
                    <FluentText Class="fc-navigation-rail__label"
                                Size="TextSize.Size200"
                                Weight="@(activeContext ? TextWeight.Semibold : TextWeight.Regular)">@LocalizeManifestName(manifest)</FluentText>
                }
            </FluentStack>
            @if (aggregateCount > 0 || bcShowsNew)
            {
                <FluentStack Class="fc-navigation-rail__tile-badges"
                             Horizontal="true"
                             HorizontalAlignment="HorizontalAlignment.End"
                             VerticalAlignment="VerticalAlignment.Center"
                             HorizontalGap="2px">
                    @if (aggregateCount > 0)
                    {
                        <FluentBadge Appearance="@BadgeAppearance.Filled"
                                     Color="@BadgeColor.Brand"
                                     data-testid="@($"fc-rail-badge-{manifest.BoundedContext}")">@aggregateCount</FluentBadge>
                    }
                    @if (bcShowsNew)
                    {
                        <FluentBadge Appearance="@BadgeAppearance.Tint"
                                     Color="@BadgeColor.Informative"
                                     data-testid="@($"fc-rail-new-{manifest.BoundedContext}")">@Localizer["NewCapabilityBadgeText"].Value</FluentBadge>
                    }
                </FluentStack>
            }
        </FluentButton>
        <FluentTooltip Anchor="@anchorId" Positioning="@Positioning.After" UseTooltipService="false">
            @LocalizeManifestName(manifest)
        </FluentTooltip>
        <FluentMenu Trigger="@anchorId"
                    PersistOnItemClick="false"
                    data-testid="@($"fc-nav-flyout-{manifest.BoundedContext}")"
                    role="menu"
                    aria-label="@LocalizeManifestName(manifest)">
            @foreach (string projectionFqn in projections)
            {
                int count = LookupCount(projectionFqn, discovery.Counts);
                string label = ProjectionLabel(projectionFqn);
                string route = BuildRoute(manifest.BoundedContext, projectionFqn);
                string projCapabilityId = CapabilityIds.ForProjection(manifest.BoundedContext, projectionFqn);
                bool projShowsNew = !discovery.SeenCapabilities.Contains(projCapabilityId) && count > 0;
                bool activeProjection = IsHrefActive(route);

                <FluentMenuItem Role="@MenuItemRole.MenuItem"
                                IconStart="@ResolveNavEntryIcon(manifest.Icon, activeProjection)"
                                OnClick="@(_ => HandleProjectionMenuItemClicked(manifest.BoundedContext, projectionFqn, route))"
                                data-testid="@($"fc-nav-flyout-projection-{manifest.BoundedContext}-{label}")"
                                data-href="@route"
                                aria-current="@(activeProjection ? "page" : null)">
                    <FluentStack Horizontal="true"
                                 VerticalAlignment="VerticalAlignment.Center"
                                 HorizontalGap="6px">
                        <FluentText>@label</FluentText>
                        @if (count > 0)
                        {
                            <FluentBadge Appearance="@BadgeAppearance.Filled"
                                         Color="@BadgeColor.Brand"
                                         data-testid="@($"fc-nav-badge-{manifest.BoundedContext}-{label}")">@count</FluentBadge>
                        }
                        @if (projShowsNew)
                        {
                            <FluentBadge Appearance="@BadgeAppearance.Tint"
                                         Color="@BadgeColor.Informative"
                                         data-testid="@($"fc-nav-new-{manifest.BoundedContext}-{label}")">
                                @Localizer["NewCapabilityBadgeText"].Value
                            </FluentBadge>
                        }
                    </FluentStack>
                </FluentMenuItem>
            }
            @foreach (FrontComposerNavEntry entry in entries)
            {
                @navEntry(entry)
            }
        </FluentMenu>
    }
    @foreach (string orphanBc in OrphanEntryContexts(navEntries))
    {
        List<FrontComposerNavEntry> entries = EntriesForContext(navEntries, orphanBc);
        string anchorId = RailAnchorId(orphanBc);
        bool activeContext = IsContextActive(orphanBc, [], entries);

        <FluentButton id="@anchorId"
                      Appearance="@ButtonAppearance.Subtle"
                      Class="@ContextTileClass(activeContext)"
                      Title="@(iconOnly ? orphanBc : null)"
                      aria-label="@(iconOnly ? orphanBc : null)"
                      aria-current="@(activeContext ? "page" : null)"
                      data-testid="@($"fc-nav-context-{orphanBc}")"
                      data-active="@activeContext"
                      tabindex="0"
                      OnClick="@(_ => HandleContextTileActivated(orphanBc))">
            <FluentStack Class="fc-navigation-rail__tile-content"
                         Orientation="Orientation.Vertical"
                         HorizontalAlignment="HorizontalAlignment.Center"
                         VerticalAlignment="VerticalAlignment.Center"
                         VerticalGap="2px"
                         Width="100%">
                <FluentIcon Value="@ResolveNavEntryIcon(null, activeContext)" Color="Color.Primary" />
                @if (!iconOnly)
                {
                    <FluentText Class="fc-navigation-rail__label"
                                Size="TextSize.Size200"
                                Weight="@(activeContext ? TextWeight.Semibold : TextWeight.Regular)">@orphanBc</FluentText>
                }
            </FluentStack>
        </FluentButton>
        <FluentTooltip Anchor="@anchorId" Positioning="@Positioning.After" UseTooltipService="false">
            @orphanBc
        </FluentTooltip>
        <FluentMenu Trigger="@anchorId"
                    PersistOnItemClick="false"
                    data-testid="@($"fc-nav-flyout-{orphanBc}")"
                    role="menu"
                    aria-label="@orphanBc">
            @foreach (FrontComposerNavEntry entry in entries)
            {
                @navEntry(entry)
            }
        </FluentMenu>
    }
</FluentStack>
</div>
