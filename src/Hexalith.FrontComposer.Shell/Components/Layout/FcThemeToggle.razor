@namespace Hexalith.FrontComposer.Shell.Components.Layout
@using Microsoft.FluentUI.AspNetCore.Components
@using Hexalith.FrontComposer.Shell.Resources
@using Hexalith.FrontComposer.Shell.State.Theme
@inherits Fluxor.Blazor.Web.Components.FluxorComponent
@inject IStringLocalizer<FcShellResources> Localizer

@* Story 3-1 D5 / D7 / D22 — Light/Dark/System theme toggle. Dispatches ThemeChangedAction
   (single writer per D7); the effect handles persistence + IThemeService.SetThemeAsync.
   Decorative icons (D5) are deferred — Fluent UI v5 RC2 ships without a v5-compatible Icons
   package; the toggle labels carry the full accessible meaning so the UX still satisfies AC3. *@

<FluentMenu>
    <FluentMenuButton Appearance="ButtonAppearance.Subtle"
                      Title="@Localizer["ThemeToggleAriaLabel"].Value"
                      Style="min-width: 0; width: 48px;">
        <span class="fc-sr-only">@GetAccessibleLabel()</span>
        <span aria-hidden="true">@Localizer[GetCurrentLabelKey()].Value</span>
    </FluentMenuButton>
    <FluentMenuList>
        @* Fluent UI v5: menu-item activation is surfaced via the FluentMenuItem OnClick
           EventCallback<MenuItemEventArgs>, NOT @onclick. Using @onclick faults at runtime when
           the menu is used (see Fluent UI v5 migration guide → Menu). *@
        <FluentMenuItem OnClick="@(_ => SelectThemeAsync(ThemeValue.Light))"
                        aria-label="@Localizer["ThemeLightLabel"].Value">
            @Localizer["ThemeLightLabel"].Value
        </FluentMenuItem>
        <FluentMenuItem OnClick="@(_ => SelectThemeAsync(ThemeValue.Dark))"
                        aria-label="@Localizer["ThemeDarkLabel"].Value">
            @Localizer["ThemeDarkLabel"].Value
        </FluentMenuItem>
        <FluentMenuItem OnClick="@(_ => SelectThemeAsync(ThemeValue.System))"
                        aria-label="@Localizer["ThemeSystemLabel"].Value">
            @Localizer["ThemeSystemLabel"].Value
        </FluentMenuItem>
    </FluentMenuList>
</FluentMenu>
