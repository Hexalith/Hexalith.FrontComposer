@namespace Hexalith.FrontComposer.Shell.Components.Layout
@using Microsoft.Extensions.Localization
@using Microsoft.FluentUI.AspNetCore.Components
@using Hexalith.FrontComposer.Shell.Resources
@inject IStringLocalizer<FcShellResources> Localizer

@* Framework-owned account control: a FluentAvatar in the shell header that opens a sign in / sign
   out menu — the Fluent UI idiom for header authentication affordances. The current principal is
   read from AuthenticationStateProvider (the established Shell seam, cf. CommandAuthorizationEvaluator)
   rather than <AuthorizeView>, so the control renders without a cascading Task<AuthenticationState>
   in component tests and falls back to the anonymous (Sign in) state when no host auth is wired.
   Sign in / out navigate to the framework auth endpoints with forceLoad so the OIDC challenge /
   sign-out round-trips through the server (equivalent to the retired auth-bar's data-enhance-nav). *@

<FluentStack Orientation="Orientation.Horizontal"
             VerticalAlignment="VerticalAlignment.Center"
             HorizontalGap="8px"
             Width="fit-content"
             Class="fc-account-menu"
             data-testid="fc-account-menu">
    @if (IsAuthenticated)
    {
        <FluentAvatar Id="@AvatarId"
                      Name="@UserName"
                      Color="AvatarColor.Colorful"
                      Title="@SignedInAsText"
                      Style="cursor: pointer;" />
        <FluentMenu Trigger="@AvatarId">
            <FluentMenuList Style="@MenuListStyle"
                            role="menu"
                            aria-label="@Localizer["AccountMenuAriaLabel"].Value">
                @* Show the (short) name as the item text — the full "Signed in as {name}" sentence is
                   long and would widen the menu, so it stays as the accessible title/tooltip. (The
                   list is right-anchored to the avatar via MenuListStyle so it no longer clips at the
                   viewport's right edge.) *@
                <FluentMenuItem Disabled="true" data-testid="fc-account-user" Title="@SignedInAsText">
                    <span class="fc-account-menu__menu-user">@UserName</span>
                </FluentMenuItem>
                <FluentDivider />
                <FluentMenuItem OnClick="@(_ => SignOut())" data-testid="fc-account-sign-out">
                    @Localizer["SignOutLabel"].Value
                </FluentMenuItem>
            </FluentMenuList>
        </FluentMenu>
    }
    else
    {
        <FluentAvatar Id="@AvatarId"
                      Title="@Localizer["AccountMenuAriaLabel"].Value"
                      Style="cursor: pointer;" />
        <FluentMenu Trigger="@AvatarId">
            <FluentMenuList Style="@MenuListStyle"
                            role="menu"
                            aria-label="@Localizer["AccountMenuAriaLabel"].Value">
                <FluentMenuItem OnClick="@(_ => SignIn())" data-testid="fc-account-sign-in">
                    @Localizer["SignInLabel"].Value
                </FluentMenuItem>
            </FluentMenuList>
        </FluentMenu>
    }
</FluentStack>
