@namespace Hexalith.FrontComposer.Shell.Components.Layout
@using Hexalith.FrontComposer.Contracts.Rendering
@using Hexalith.FrontComposer.Shell.Resources
@using Hexalith.FrontComposer.Shell.State.Density
@using Microsoft.Extensions.Localization
@using Microsoft.FluentUI.AspNetCore.Components
@inherits Fluxor.Blazor.Web.Components.FluxorComponent
@inject IStringLocalizer<FcShellResources> Localizer

@* Story 3-3 Task 6.1 (D13, D14, D15, D17; AC2, AC4, AC5) — settings dialog with density radio,
   embedded FcThemeToggle, live preview panel, and a "Reset to defaults" footer button. No
   Apply/Cancel — changes are live per epic AC §126; Done closes the dialog. Opens via IDialogService.ShowDialogAsync
   (dispatched by FcSettingsButton and the Ctrl+, handler on FrontComposerShell). *@

<FluentDialogBody>
    <TitleTemplate>
        @Localizer["SettingsDialogTitle"].Value
    </TitleTemplate>
    <ChildContent>
        @* §4.2 — the three titled sections (Density / Theme / Preview) are grouped in one
           FluentAccordion, one FluentAccordionItem per section, with the primary (Density) item
           Expanded. The dialog body is a plain <div> because the accordion now owns the sectioning,
           so the prior single-child <FluentStack> wrapper is dropped (§4.3). Id="fc-theme-section"
           preserves the e2e theme-section anchor; the radio group keeps its accessible name via
           aria-label now that the heading is owned by the accordion item. *@
        <div class="fc-settings-body" data-testid="fc-settings-dialog">
            <FluentAccordion>
                <FluentAccordionItem Header="@Localizer["DensitySectionLabel"].Value" Expanded="true">
                    <FluentRadioGroup Value="@SelectedDensity"
                                      ValueChanged="@((DensityLevel v) => SelectedDensity = v)"
                                      TValue="DensityLevel"
                                      Name="fc-density-select"
                                      aria-label="@Localizer["DensitySectionLabel"].Value">
                        <FluentRadio Value="@DensityLevel.Compact">@Localizer["DensityCompactLabel"].Value</FluentRadio>
                        <FluentRadio Value="@DensityLevel.Comfortable">@Localizer["DensityComfortableLabel"].Value</FluentRadio>
                        <FluentRadio Value="@DensityLevel.Roomy">@Localizer["DensityRoomyLabel"].Value</FluentRadio>
                    </FluentRadioGroup>
                    @if (IsForcedByViewport)
                    {
                        <FluentMessageBar Intent="MessageBarIntent.Info"
                                          AllowDismiss="false"
                                          data-testid="fc-settings-forced-note">
                            @Localizer["DensityForcedByViewportNote"].Value
                        </FluentMessageBar>
                    }
                </FluentAccordionItem>
                <FluentAccordionItem Id="fc-theme-section" Header="@Localizer["ThemeSectionLabel"].Value">
                    <FcThemeToggle />
                </FluentAccordionItem>
                <FluentAccordionItem Header="@Localizer["DensityPreviewHeading"].Value">
                    <FcDensityPreviewPanel Density="@SelectedDensity"
                                           ShowForcedViewportBadge="@(IsForcedByViewport && SelectedDensity != DensityLevel.Comfortable)" />
                </FluentAccordionItem>
            </FluentAccordion>
        </div>
    </ChildContent>
    <ActionTemplate>
        <div class="fc-settings-footer">
            <div class="fc-settings-footer-stack">
                <FluentButton Appearance="ButtonAppearance.Outline"
                              OnClick="RestoreDefaultsAsync"
                              data-testid="fc-settings-reset">
                    @Localizer["RestoreDefaultsLabel"].Value
                </FluentButton>
                <span class="fc-settings-footer-helper">
                    @Localizer["RestoreDefaultsHelperText"].Value
                </span>
            </div>
            <FluentButton Appearance="ButtonAppearance.Primary"
                          OnClick="CloseAsync"
                          Class="fc-settings-done"
                          data-testid="fc-settings-done">
                @Localizer["SettingsDialogDoneLabel"].Value
            </FluentButton>
        </div>
    </ActionTemplate>
</FluentDialogBody>
