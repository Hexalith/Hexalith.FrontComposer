@namespace Hexalith.FrontComposer.Shell.Components.Layout
@using Microsoft.AspNetCore.Components.Web
@using Microsoft.FluentUI.AspNetCore.Components

<PageTitle>@ResolvedPageTitle</PageTitle>

@* role="presentation" — the page header is purely visual chrome scoped inside the shell's single
   #fc-main-content `main` landmark. Stripping the implicit `banner` role guarantees exactly one
   banner per page (owned by the shell header), even when an adopter renders this header outside a
   sectioning ancestor. The route heading keeps its own h1 semantics independently.
   role is emitted AFTER @attributes so a splatted adopter `role` (captured via AdditionalAttributes)
   cannot override the presentation role and silently re-introduce a competing banner landmark. *@
<header class="@CssClass" data-testid="@TestId" @attributes="AdditionalAttributes" role="@LandmarkRole">
    <FluentStack Orientation="Orientation.Vertical" VerticalGap="8px" Width="100%">
        @if (!string.IsNullOrWhiteSpace(Eyebrow))
        {
            <FluentText As="TextTag.Paragraph"
                        Size="TextSize.Size200"
                        Weight="TextWeight.Semibold"
                        Color="Color.Lightweight"
                        Style="margin: 0;"
                        data-fc-page-header-eyebrow>
                @Eyebrow
            </FluentText>
        }

        <FluentStack Orientation="Orientation.Horizontal"
                     HorizontalAlignment="HorizontalAlignment.SpaceBetween"
                     VerticalAlignment="VerticalAlignment.Top"
                     HorizontalGap="16px"
                     VerticalGap="8px"
                     Wrap="true"
                     Width="100%">
            @* Blank-heading fail-safe (Requested outcome 3): suppress the h1 entirely when Heading is
               blank/whitespace so the route never renders a dangling empty heading element. *@
            @if (HasHeading)
            {
                <h1 id="@HeadingId"
                    tabindex="@HeadingTabIndex"
                    style="margin: 0;"
                    @ref="_headingElement">
                    <FluentText As="TextTag.Span" Size="TextSize.Size700" Weight="TextWeight.Semibold">@Heading</FluentText>
                </h1>
            }

            @if (Actions is not null)
            {
                <FluentStack Orientation="Orientation.Horizontal"
                             HorizontalGap="8px"
                             VerticalGap="8px"
                             Wrap="true"
                             data-fc-page-header-actions>
                    @Actions
                </FluentStack>
            }
        </FluentStack>

        @if (!string.IsNullOrWhiteSpace(Description))
        {
            <FluentText As="TextTag.Paragraph"
                        Size="TextSize.Size300"
                        Style="margin: 0;"
                        data-fc-page-header-description>
                @Description
            </FluentText>
        }

        @if (Metadata is not null)
        {
            <FluentStack Orientation="Orientation.Vertical"
                         VerticalGap="4px"
                         data-fc-page-header-metadata>
                @Metadata
            </FluentStack>
        }
    </FluentStack>
</header>
