@namespace Hexalith.FrontComposer.Shell.Components.EventStore
@using Hexalith.FrontComposer.Shell.State.PendingCommands
@using Microsoft.FluentUI.AspNetCore.Components

@if (SummaryEntries.Count > 0)
{
    <section class="fc-pending-command-summary"
             aria-live="polite"
             data-testid="fc-pending-command-summary">
        <div class="fc-pending-command-summary__counts">@SummaryText</div>
        <FluentStack Orientation="Orientation.Vertical" VerticalGap="0.375rem" Class="fc-pending-command-summary__details">
            @foreach (PendingCommandEntry entry in VisibleEntries)
            {
                if (entry.Status == PendingCommandStatus.Rejected)
                {
                    <FluentMessageBar Intent="MessageBarIntent.Error"
                                      AllowDismiss="false"
                                      data-allow-dismiss="false">
                        @FormatRejected(entry)
                    </FluentMessageBar>
                }
                else
                {
                    <div class="fc-pending-command-summary__row">@FormatEntry(entry)</div>
                }
            }
            @if (OverflowCount > 0)
            {
                <div class="fc-pending-command-summary__overflow">@OverflowText</div>
            }
        </FluentStack>
    </section>
}
