@namespace Hexalith.FrontComposer.Shell.Components.Rendering
@using Microsoft.FluentUI.AspNetCore.Components

<div role="status"
     aria-busy="true"
     aria-label="@ResolvedAriaLabel"
     class="@CssClass">
    @if (Layout == SkeletonLayout.Card)
    {
        <div class="fc-projection-skeleton-card">
            <FluentSkeleton Height="32px" Width="40%" Shape="SkeletonShape.Rectangle" />
            @for (int i = 0; i < RowCount; i++)
            {
                <div class="fc-projection-skeleton-row">
                    <FluentSkeleton Height="16px" Width="24%" Shape="SkeletonShape.Rectangle" />
                    <FluentSkeleton Height="16px" Width="60%" Shape="SkeletonShape.Rectangle" />
                </div>
            }
        </div>
    }
    else if (Layout == SkeletonLayout.Timeline)
    {
        <div class="fc-projection-skeleton-timeline">
            @for (int i = 0; i < RowCount; i++)
            {
                <div class="fc-projection-skeleton-row">
                    <FluentSkeleton Height="20px" Width="20%" Shape="SkeletonShape.Rectangle" />
                    <FluentSkeleton Height="16px" Width="55%" Shape="SkeletonShape.Rectangle" />
                    <FluentSkeleton Height="20px" Width="15%" Shape="SkeletonShape.Rectangle" />
                </div>
            }
        </div>
    }
    else
    {
        <div class="fc-projection-skeleton-grid">
            <div class="fc-projection-skeleton-row fc-projection-skeleton-header">
                @for (int c = 0; c < ColumnCount; c++)
                {
                    <FluentSkeleton Height="16px" Width="@HeaderCellWidth" Shape="SkeletonShape.Rectangle" />
                }
            </div>
            @for (int i = 0; i < RowCount; i++)
            {
                <div class="fc-projection-skeleton-row">
                    @for (int c = 0; c < ColumnCount; c++)
                    {
                        <FluentSkeleton Height="14px" Width="@BodyCellWidth" Shape="SkeletonShape.Rectangle" />
                    }
                </div>
            }
        </div>
    }
</div>
