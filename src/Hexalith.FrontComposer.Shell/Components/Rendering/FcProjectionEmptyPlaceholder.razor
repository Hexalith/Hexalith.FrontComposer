@namespace Hexalith.FrontComposer.Shell.Components.Rendering
@using Hexalith.FrontComposer.Shell.Components.Icons
@using Hexalith.FrontComposer.Contracts.Rendering
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.FluentUI.AspNetCore.Components

<div role="status"
     aria-label="@ResolvedAriaLabel"
     class="fc-empty-state-body fc-projection-empty-placeholder">
    <FluentIcon Value="@FcFluentIcons.DocumentSearch48()" Color="Color.Default" Class="fc-empty-state-body__icon" />
    <FluentLabel Typography="Typography.Body1" Class="fc-projection-empty-placeholder-text">@DisplayMessage</FluentLabel>
    @if (_resolvedCta is { } cta && !string.IsNullOrWhiteSpace(cta.CommandRoute))
    {
        @if (cta.AuthorizationPolicy is { Length: > 0 } policy)
        {
            Type? ctaCommandType = ResolveCommandType(cta.CommandFqn);
            if (ctaCommandType is not null)
            {
                <FcAuthorizedCommandRegion CommandType="ctaCommandType"
                                           PolicyName="@policy"
                                           BoundedContext="@cta.BoundedContext"
                                           DisplayLabel="@cta.CommandDisplayName">
                    <Authorized>
                        @RenderCta(cta)
                    </Authorized>
                </FcAuthorizedCommandRegion>
            }
        }
        else
        {
            <AuthorizeView>
                <Authorized>
                    @RenderCta(cta)
                </Authorized>
            </AuthorizeView>
        }
    }
    @if (ResolvedSecondaryText is { Length: > 0 } secondary)
    {
        <FluentLabel Typography="Typography.Body2"
                     Class="fc-projection-empty-placeholder-secondary">
            @secondary
        </FluentLabel>
    }
</div>
