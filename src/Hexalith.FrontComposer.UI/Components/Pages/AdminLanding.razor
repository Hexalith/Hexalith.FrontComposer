@page "/admin"
@attribute [Authorize(Policy = PartiesUiAuthorization.AdminPolicy)]
@inject NavigationManager Nav

<FcPageLayout Mode="FcPageLayoutMode.Constrained">
    <FcPageHeader Heading="Administration"
                  Description="Opening the Parties administration workspace." />
</FcPageLayout>

@code {
    protected override void OnInitialized()
        => Nav.NavigateTo(PartiesAdminPortalManifest.Route);
}
