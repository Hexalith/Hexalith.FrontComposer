@page "/counter"
@implements IDisposable
@using Counter.Domain
@using System.Collections.Immutable

<PageTitle>Counter sample</PageTitle>
@inject IState<Counter.Domain.CounterProjectionState> CounterState

<h1>Counter</h1>

<CascadingValue Value="_demoContext">
    <div class="page-container" style="display: flex; flex-direction: column; gap: 24px;">
        @* §4.2 — the three titled command-density specimen sections are grouped in one
           FluentAccordion. ExpandMode=Multi with every item Expanded keeps all three densities
           visible side-by-side (the specimen's purpose + the a11y/visual + command-form e2e gate)
           while still adding the accordion's collapse affordance. HeadingLevel=2 preserves the
           prior <h2> heading order under the page <h1>. The .command-section/.inline-section/
           .fullpage-section classes are kept on the items for the e2e selectors. *@
        <FluentAccordion ExpandMode="AccordionExpandMode.Multi" HeadingLevel="2">
            <FluentAccordionItem Class="command-section" Heading="Compact inline (3 fields)" Expanded="true">
                <BatchIncrementCommandRenderer />
            </FluentAccordionItem>
            <FluentAccordionItem Class="inline-section" Heading="Inline + popover (1 field)" Expanded="true">
                <IncrementCommandRenderer />
            </FluentAccordionItem>
            <FluentAccordionItem Class="fullpage-section" Heading="Full-page command (5 fields)" Expanded="true">
                <p role="note" style="padding: 12px; background: var(--colorNeutralBackground2); border-left: 4px solid var(--colorBrandStroke1);">
                    Navigation state persistence (scroll, filter, sort across FullPage round-trip) lands in Story 4.3.
                    The current demo proves routing + breadcrumb return only.
                </p>
                <a href="/commands/Counter/ConfigureCounterCommand?returnPath=%2Fcounter&amp;projectionTypeFqn=Counter.Domain.CounterProjection">Configure Counter</a>
            </FluentAccordionItem>
        </FluentAccordion>
        <section class="data-section">
            @if (CounterState.Value.IsLoading || CounterState.Value.Items?.Count > 0)
            {
                <CounterProjectionView />
            }
            else
            {
                <FluentStack Orientation="Orientation.Vertical"
                             HorizontalAlignment="HorizontalAlignment.Center"
                             VerticalAlignment="VerticalAlignment.Center"
                             Style="padding: 32px; gap: 12px; text-align: center;">
                    <FluentText Size="TextSize.Size400" Weight="TextWeight.Semibold">
                        No counter data yet. Send your first Increment Counter command.
                    </FluentText>
                </FluentStack>
            }
        </section>
    </div>
</CascadingValue>

@code {
    // Story 2-2 Decision D27 — manual CascadingValue to exercise ProjectionContextProvider
    // pre-fill without Epic 4's DataGrid row cascade. Demo-only.
    private readonly Hexalith.FrontComposer.Contracts.Rendering.ProjectionContext _demoContext = new(
        projectionTypeFqn: "Counter.Domain.CounterProjection",
        boundedContext: "Counter",
        aggregateId: "counter-demo-1",
        fields: ImmutableDictionary.CreateRange<string, object?>(
            new Dictionary<string, object?> { ["TenantId"] = "counter-demo" }));

    protected override void OnInitialized()
    {
        CounterState.StateChanged += OnStateChanged;
    }

    private void OnStateChanged(object? sender, EventArgs e)
        => InvokeAsync(StateHasChanged);

    public void Dispose()
    {
        CounterState.StateChanged -= OnStateChanged;
    }
}
